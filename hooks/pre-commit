#!/bin/bash

GREEN='\033[0;32m'
RED='\033[0;31m'
BLUE='\033[0;34m'
YELLOW='\033[1;33m'
NC='\033[0m'

LOG_FILE=$(mktemp)

echo -e "${BLUE}▶ Starting Kotlin/Android Quality Checks...${NC}"

# 1. Automatic Formatting (ktlint)
echo -ne "  [1/4] Formatting (ktlint)... "
./gradlew formatKotlin > "$LOG_FILE" 2>&1
if [ $? -eq 0 ]; then
    echo -e "${GREEN}FIXED/OK${NC}"
    git add .
else
    echo -e "${RED}FAILED${NC}"
    echo -e "${YELLOW}--- FORMATTING ERROR LOG ---${NC}"
    cat "$LOG_FILE"
    rm -f "$LOG_FILE"
    exit 1
fi

# 2. Static Analysis (Detekt)
echo -ne "  [2/4] Analysis (Detekt)... "
./gradlew detekt > "$LOG_FILE" 2>&1
if [ $? -eq 0 ]; then
    echo -e "${GREEN}PASSED${NC}"
else
    echo -e "${RED}FAILED${NC}"
    echo -e "${YELLOW}--- DETEKT VIOLATIONS ---${NC}"
    cat "$LOG_FILE"
    rm -f "$LOG_FILE"
    exit 1
fi

# 3. Android Lint
echo -ne "  [3/4] Android Lint... "
./gradlew lintDebug > "$LOG_FILE" 2>&1
if [ $? -eq 0 ]; then
    echo -e "${GREEN}PASSED${NC}"
else
    echo -e "${RED}FAILED${NC}"
    echo -e "${YELLOW}--- LINT ERROR LOG ---${NC}"
    # Android Lint output can be huge, showing just the summary
    grep "Wrote HTML report to" "$LOG_FILE" || cat "$LOG_FILE"
    rm -f "$LOG_FILE"
    exit 1
fi

# 4. Unit Tests
echo -ne "  [4/4] Unit Tests... "
./gradlew testDebugUnitTest > "$LOG_FILE" 2>&1
if [ $? -eq 0 ]; then
    echo -e "${GREEN}PASSED${NC}"
else
    echo -e "${RED}FAILED${NC}"
    echo -e "${YELLOW}--- TEST FAILURE SUMMARY ---${NC}"
    # Attempt to show the specific failed test line
    grep -E "FAILED|Test" "$LOG_FILE" || cat "$LOG_FILE"
    rm -f "$LOG_FILE"
    exit 1
fi

rm -f "$LOG_FILE"
echo -e "${GREEN}✔ All checks passed! Proceeding with commit.${NC}"
exit 0